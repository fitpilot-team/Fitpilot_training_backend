# Fitpilot Training Backend - vars especificas para docker-compose raiz

# Auth compatibility with Nutrition
NUTRITION_AUTH_ME_PATH=/v1/auth/me
NUTRITION_AUTH_TIMEOUT_SECONDS=8
NUTRITION_AUTH_CACHE_TTL_SECONDS=25

# JWT / app
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_MODEL=llama3.2:3b

# Exercise media storage
EXERCISE_MEDIA_PROVIDER=local
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
