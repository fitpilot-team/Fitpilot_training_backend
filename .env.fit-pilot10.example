# Fitpilot Training Backend - vars especificas para docker-compose raiz

# DATABASE_URL is injected from the root compose env via SUPABASE_DATABASE_URL.
# It must always point to a remote PostgreSQL instance.
# For Supabase session poolers, keep SQLAlchemy conservative by default.
DATABASE_POOL_SIZE=1
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=5
DATABASE_POOL_RECYCLE_SECONDS=300

# Auth compatibility with Nutrition
NUTRITION_AUTH_ME_PATH=/v1/auth/me
NUTRITION_AUTH_TIMEOUT_SECONDS=8
NUTRITION_AUTH_CACHE_TTL_SECONDS=25
REDIS_URL=redis://app:change-me@fitpilot-redis:6379/0

# JWT / app
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_MODEL=llama3.2:3b

# Exercise media storage (R2, obligatorio)
# El fallback local fue eliminado para image_url, thumbnail_url y anatomy_image_url.
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
