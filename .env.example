# === Backend (Training API) ===

# Core
# Remote-only database. Local Postgres URLs are rejected at startup.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

# Cross-service auth (Nutrition -> Training)
NUTRITION_API_URL=https://nutrition-api.fitpilot.fit
NUTRITION_AUTH_ME_PATH=/v1/auth/introspect
NUTRITION_AUTH_TIMEOUT_SECONDS=8

# Exercise media storage (R2 only)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=fitpilot-exercise-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://cdn.fitpilot.com

# === Frontend ===

# Microfrontend Remotes Configuration
VITE_MFE_AUTH_URL=http://localhost:3001/assets/remoteEntry.js
VITE_MFE_DASHBOARD_URL=http://localhost:3002/assets/remoteEntry.js
VITE_MFE_CLIENTS_URL=http://localhost:3003/assets/remoteEntry.js
VITE_MFE_EXERCISES_URL=http://localhost:3004/assets/remoteEntry.js
VITE_MFE_TRAINING_URL=http://localhost:3005/assets/remoteEntry.js
VITE_MFE_AI_URL=http://localhost:3006/assets/remoteEntry.js

# API domains (Nutrition + Training)
VITE_NUTRITION_API_URL=http://localhost:3000
VITE_TRAINING_API_URL=http://localhost:8010
